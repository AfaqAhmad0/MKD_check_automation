# ─── AI Provider Keys ────────────────────────────────────────
# At least ONE AI key is required for the checkout summary engine.
# You can also manage these from the Settings (⚙) icon in the web UI.

GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# ─── Gitea Integration ───────────────────────────────────────
# Required for the "Check Repo Updates" feature.
# Generate a personal access token at: https://your-gitea-instance/user/settings/applications

GITEA_API_KEY=
